<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Todo App</title>

    <link
        rel="stylesheet"
        href="/static/style.css"
    >

</head>

<body>

    <!-- LOGIN SCREEN -->

    <div id="loginScreen" class="container">

        <h1>Todo App Login</h1>

        <input
            type="text"
            id="username"
            placeholder="Username"
        >

        <input
            type="password"
            id="password"
            placeholder="Password"
        >

        <div style="margin-top:15px;">

            <button id="loginBtn">
                Login
            </button>

            <button id="registerBtn">
                Register
            </button>

        </div>

        <p
            id="loginMessage"
            style="color:red;"
        ></p>

    </div>


    <!-- TODO SCREEN -->

    <div
        id="todoScreen"
        class="container"
        style="display:none;"
    >

        <h1>
            My Todo List
        </h1>

        <form id="taskForm">

            <input
                id="taskInput"
                type="text"
                placeholder="Enter a task..."
                required
            >

            <button type="submit">
                Add Task
            </button>

        </form>

        <ul id="taskList"></ul>

        <br>

        <button id="logoutBtn">
            Logout
        </button>

    </div>

    <script src="/static/app.js"></script>

</body>
</html>